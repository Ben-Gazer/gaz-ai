# OpenClaw Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Required — your OpenClaw gateway authentication token
# (copy from Hostinger hPanel → Docker Manager → OpenClaw → Environment)
OPENCLAW_GATEWAY_TOKEN=

# Port the OpenClaw container listens on (default: 18789)
OPENCLAW_PORT=18789

# Optional — AI provider API keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Optional — WhatsApp number for channel integration
WHATSAPP_NUMBER=

# Optional — Monday.com API token (for MCP integration)
# Get from: monday.com → Profile → Developers → API token
MONDAY_API_TOKEN=
